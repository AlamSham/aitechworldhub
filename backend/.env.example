PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/ai_blog
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_ACCESS_EXPIRES_IN=12h
ADMIN_SETUP_KEY=replace_with_admin_setup_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
SOURCE_MIN_RELEVANCE_SCORE=4
REQUIRE_CHINA_US_PAIR=false
MIN_WAR_HITS=1
ENABLE_CRON_SYNC=true
SYNC_INTERVAL_HOURS=6
MAX_DRAFTS_PER_SYNC=1
CHINA_US_RATIO_EVERY=5
ARTICLE_MIN_WORDS=1100
ARTICLE_MAX_WORDS=1600
LATEST_LOOKBACK_DAYS=120
TARGET_FOCUS_REGION=US,UK
ENABLE_PUBLISH_QA_GATE=false
DEFAULT_AUTHOR=Shamshad
FRONTEND_ORIGIN=http://localhost:3000
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=ai-blog/drafts
TURNSTILE_SECRET_KEY=
